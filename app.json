{
	"name": "ilovepdf_bot",
	"description": "A Telegram Bot that helps you to domany this with pdf.",
	"keywords": [
		"Telegram", "Telegram Bot", "pdf bot",
		"ilovepdf", "nabilabavab", "python",
		"ilovepdf_bot", "complete pdf bot"
	],
	"website": "https://github.com/nabilanavab/ilovepdf",
	"repository": "https://github.com/nabilanavab/ilovepdf",
	"logo": "https://te.legra.ph/file/b659b2e306bb766a44537.jpg",
	"success_url": "https://github.com/nabilanavab/ilovepdf",
	"stack": "heroku-20",
	"env": {
		"API_ID": {
			"description": "API_ID from my.telegram.org",
			"required": true
		},
		"API_HASH": {
			"description": "API_ID from my.telegram.org",
			"required": true
		},
		"API_TOKEN": {
			"description": "API_TOKEN from @botfather",
			"required": true
		},
		"UPDATE_CHANNEL": {
			"description": "ChannelId, if force Subscription needed",
			"required": false
		},
		"ADMINS": {
			"description": "ADMINs TELEGRAM ID (only the can manage bots)",
			"required": false
		},
		"ADMIN_ONLY": {
			"description": "If True, Only admins Can use",
			"required": false
		},
		"MAX_FILE_SIZE": {
			"description": "for preventing overload (in mb)",
			"required": false
		},
		"MONGODB_URI": {
			"description": "Get MongoDB url from mongodb.com",
			"required": false
		},
		"LOG_CHANNEL": {
			"description": "Dump Channel (Where the bot Dump all mani. files",
			"required": false
		},
		"BANNED_USERS": {
			"description": "BANNED USERS ID (no DB required)",
			"required": false
		},
		"DEFAULT_NAME": {
			"description": "if Set, all manipulated PDF have this name 😉",
			"required": false
		},
		"ADMIN_GROUPS": {
			"description": "Admin Group ID",
			"required": false
		},
		"ADMIN_GROUP_ONLY": {
			"description": "True, if only for admin group",
			"required": false
		},
		"BANNED_GROUP": {
			"description": "Group ID, to ban specific group",
			"required": false
		},
		"ONLY_GROUP_ADMIN": {
			"description": "Only Group Admins Can Use =)",
			"required": false
		},
	},
	"buildpacks": [
		{
			"url": "heroku/python"
		}
	]
}
